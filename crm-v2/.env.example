# Supabase v2 — schema `crm` del proyecto compartido (addendum §21 2026-07-08).
# Copiar a .env.local (gitignored) y completar.
# NUNCA hardcodear credenciales en el código (regla plan-m0-m1 §0).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional: mostrar /design en producción (dev-only por defecto)
# NEXT_PUBLIC_SHOW_DESIGN=1

# PoC escaneo (server-only, NUNCA NEXT_PUBLIC): key de Roboflow; workspace/workflow
# tienen default en codigo (jzs-workspace/easyocr-demo) y se overridean por env.
ROBOFLOW_API_KEY=
# ROBOFLOW_WORKSPACE=jzs-workspace
# ROBOFLOW_WORKFLOW_ID=easyocr-demo
# ROBOFLOW_API_URL=https://serverless.roboflow.com
